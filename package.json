{
  "name": "webapp-m2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-reactjs": "npm install --prefix reactjs",
    "install-api": "npm install --prefix CrudAPI",
    "build-reactjs": "npm run build --prefix reactjs",
    "heroku-postbuild": "concurrently \"npm:install-*\" \"npm:build-*\"",
    "start": "npm start --prefix CrudAPI",
    "dev:react": "concurrently --raw \"npm run api\" \"npm run react\"",
    "react": "cd reactjs && npm start",
    "api": "cd CrudAPI && nodemon server.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}